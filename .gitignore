# Gradle
.gradle/
build/

# Release build outputs (APK, baseline profiles, metadata — regenerated by `gradlew assembleRelease`)
app/release/
release/

# Android Studio / IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
captures/
.externalNativeBuild/
.cxx/

# Local configuration (machine-specific SDK path, secrets)
local.properties

# Local AI assistant / editor config (personal, not shared).
# Note: shared config like .claude/settings.json or .github/ stays tracked on purpose.
.claude/settings.local.json
.cursor/
.aider*
.windsurf/

# Signing keys — never commit these
*.jks
*.keystore

# Logs
*.log

# OS files
.DS_Store
Thumbs.db
